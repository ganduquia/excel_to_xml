<tr class="item-row">
  <td><%= f.text_field :description, placeholder: "Descripción", class: "form-control form-control-sm" %></td>
  <td><%= f.number_field :quantity, min: 0.01, step: 0.01, class: "form-control form-control-sm" %></td>
  <td><%= f.number_field :unit_price_cents, min: 0, step: 1, placeholder: "0", class: "form-control form-control-sm" %></td>
  <td><%= f.number_field :discount_cents, min: 0, step: 1, class: "form-control form-control-sm" %></td>
  <td>
    <%= f.select :tax_status,
          [["Gravado","taxed"],["Excluido","excluded"],["Exento","exempt"]],
          {},
          class: "form-select form-select-sm tax-status-select" %>
  </td>
  <td>
    <%= f.select :tax_rate_id,
          @tax_rates.map { |r| [r.name, r.id] },
          { include_blank: "— Sin tarifa —" },
          class: "form-select form-select-sm tax-rate-select" %>
  </td>
  <td>
    <button type="button" class="btn btn-sm btn-outline-danger remove-item">
      <i class="bi bi-trash"></i>
    </button>
  </td>
</tr>
