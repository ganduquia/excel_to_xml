<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <%= link_to taxes_root_path, class: "text-decoration-none text-muted small" do %>
        <i class="bi bi-arrow-left me-1"></i>Dashboard
      <% end %>
      <h3 class="mb-0 fw-bold mt-1"><i class="bi bi-percent me-2 text-primary"></i>Tarifas de Impuesto</h3>
    </div>
    <%= link_to new_taxes_tax_rate_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-circle me-2"></i>Nueva tarifa
    <% end %>
  </div>

  <% if notice %>
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle me-2"></i><%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Nombre</th>
            <th>Tipo</th>
            <th class="text-end">Tarifa</th>
            <th>Vigencia desde</th>
            <th>Vigencia hasta</th>
            <th>Estado</th>
            <th>Notas</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @rates.each do |rate| %>
            <tr>
              <td class="fw-semibold"><%= rate.name %></td>
              <td><span class="badge bg-secondary"><%= rate.tax_type.upcase %></span></td>
              <td class="text-end fw-bold text-primary"><%= rate.rate %>%</td>
              <td><%= rate.effective_from&.strftime("%d/%m/%Y") %></td>
              <td><%= rate.effective_to&.strftime("%d/%m/%Y") || "Sin vencimiento" %></td>
              <td>
                <span class="badge <%= rate.active? ? 'bg-success' : 'bg-secondary' %>">
                  <%= rate.active? ? "Activa" : "Inactiva" %>
                </span>
              </td>
              <td class="text-muted small" style="max-width:200px"><%= rate.notes&.truncate(60) %></td>
              <td>
                <% if rate.active? %>
                  <%= button_to taxes_tax_rate_path(rate), method: :delete,
                        class: "btn btn-sm btn-outline-danger",
                        data: { confirm: "¿Desactivar la tarifa '#{rate.name}'?" } do %>
                    <i class="bi bi-toggle-on"></i>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
