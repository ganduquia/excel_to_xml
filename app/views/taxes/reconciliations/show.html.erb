<div class="container-fluid py-4">

  <%# ── Encabezado ──────────────────────────────────────────────────────── %>
  <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
      <%= link_to taxes_reconciliations_path, class: "text-decoration-none text-muted small" do %>
        <i class="bi bi-arrow-left me-1"></i>Conciliaciones
      <% end %>
      <h3 class="mb-0 fw-bold mt-1">
        <i class="bi bi-balance-scale me-2 text-primary"></i><%= @period.name %>
      </h3>
      <div class="text-muted small mt-1">
        Año fiscal <%= @period.fiscal_year %>
        <% if @period.company_name.present? %>
          &nbsp;·&nbsp;<%= @period.company_name %>
          <% if @period.company_nit.present? %>&nbsp;·&nbsp;NIT <%= @period.company_nit %><% end %>
        <% end %>
        &nbsp;·&nbsp;Tasa ID: <strong><%= (@period.deferred_tax_rate * 100).round(1) %>%</strong>
        &nbsp;·&nbsp;<span class="badge <%= status_badge_class(@period.status) %>">
          <%= t_recon_status(@period.status) %>
        </span>
      </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
      <% if @period.editable? && @stats[:auxiliar_total] > 0 && @period.approvable? %>
        <%= button_to approve_taxes_reconciliation_path(@period), method: :post,
              class: "btn btn-success",
              data: { confirm: "¿Aprobar la conciliación? Esta acción no se puede deshacer." } do %>
          <i class="bi bi-check2-circle me-1"></i>Aprobar
        <% end %>
      <% end %>
      <% if @stats[:auxiliar_total] > 0 %>
        <%= link_to export_taxes_reconciliation_path(@period), class: "btn btn-outline-success" do %>
          <i class="bi bi-file-earmark-excel me-2"></i>Exportar soporte .xlsx
        <% end %>
      <% end %>
    </div>
  </div>

  <% if notice %>
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle me-2"></i><%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>
  <% if alert %>
    <div class="alert alert-danger alert-dismissible fade show">
      <i class="bi bi-exclamation-triangle me-2"></i><%= alert %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <%# ── Tarjetas de resumen ─────────────────────────────────────────────── %>
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center h-100">
        <div class="card-body py-3">
          <div class="fs-4 fw-bold text-primary"><%= @stats[:auxiliar_total] %></div>
          <div class="text-muted small">Auxiliares</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center h-100">
        <div class="card-body py-3">
          <div class="fs-4 fw-bold text-warning"><%= @stats[:pending] %></div>
          <div class="text-muted small">Sin revisar</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center h-100">
        <div class="card-body py-3">
          <div class="fs-4 fw-bold text-success"><%= @stats[:reviewed] %></div>
          <div class="text-muted small">Revisados</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center h-100">
        <div class="card-body py-3">
          <div class="fs-4 fw-bold text-info"><%= @stats[:with_effect] %></div>
          <div class="text-muted small">Con ajuste</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center h-100">
        <div class="card-body py-3">
          <div class="fs-5 fw-bold text-success"><%= format_cop(@stats[:deferred_asset]) %></div>
          <div class="text-muted small">Activo ID</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center h-100">
        <div class="card-body py-3">
          <div class="fs-5 fw-bold text-danger"><%= format_cop(@stats[:deferred_liab]) %></div>
          <div class="text-muted small">Pasivo ID</div>
        </div>
      </div>
    </div>
  </div>

  <%# ── Barra de progreso ───────────────────────────────────────────────── %>
  <% if @stats[:auxiliar_total] > 0 %>
    <div class="mb-4">
      <div class="d-flex justify-content-between small text-muted mb-1">
        <span>Avance de conciliación</span>
        <span class="fw-semibold"><%= @period.completion_percentage %>% — <%= @stats[:reviewed] %> de <%= @stats[:auxiliar_total] %> cuentas revisadas</span>
      </div>
      <div class="progress" style="height:10px">
        <div class="progress-bar bg-success" style="width:<%= @period.completion_percentage %>%"></div>
      </div>
      <% if @stats[:pending] > 0 %>
        <div class="text-muted small mt-1">
          <i class="bi bi-exclamation-circle text-warning me-1"></i>
          Faltan <strong><%= @stats[:pending] %></strong> cuentas por revisar para poder aprobar.
        </div>
      <% else %>
        <div class="text-success small mt-1 fw-semibold">
          <i class="bi bi-check-circle me-1"></i>Todas las cuentas revisadas. La conciliación puede aprobarse.
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── Carga de Excel ──────────────────────────────────────────────────── %>
  <% if @period.editable? %>
    <div class="card border-0 shadow-sm mb-4 border-start border-4 border-primary">
      <div class="card-body">
        <h6 class="fw-semibold mb-2">
          <i class="bi bi-cloud-upload me-2 text-primary"></i>
          <%= @stats[:auxiliar_total] > 0 ? "Reimportar balance" : "Cargar balance de comprobación" %>
          <small class="text-muted fw-normal">(se importan solo cuentas Auxiliar)</small>
        </h6>
        <%= form_with url: import_taxes_reconciliation_path(@period),
              method: :post, multipart: true, class: "d-flex gap-2 align-items-end flex-wrap" do |f| %>
          <div>
            <%= f.file_field :file, accept: ".xlsx,.xls",
                  class: "form-control form-control-sm", style: "max-width:340px" %>
            <div class="form-text">
              Formato esperado: Nivel · Código contable · Cuenta contable · Saldo Inicial · Débito · Crédito · Saldo Final
            </div>
          </div>
          <%= f.submit "Importar", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Buscador y filtros ──────────────────────────────────────────────── %>
  <% if @stats[:auxiliar_total] > 0 %>
    <%= form_with url: taxes_reconciliation_path(@period), method: :get,
          class: "d-flex gap-2 mb-3 flex-wrap align-items-center",
          html: { "data-turbo" => "false" } do |f| %>
      <div class="input-group" style="max-width:300px">
        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
        <%= f.text_field :q, value: params[:q], placeholder: "Buscar por código o nombre…",
              class: "form-control border-start-0" %>
      </div>
      <div class="d-flex gap-1">
        <%= link_to taxes_reconciliation_path(@period),
              class: "btn btn-sm #{params[:filter].blank? && params[:q].blank? ? 'btn-dark' : 'btn-outline-secondary'}" do %>
          Todas (<%= @stats[:auxiliar_total] %>)
        <% end %>
        <%= link_to taxes_reconciliation_path(@period, filter: "auxiliar_pending"),
              class: "btn btn-sm #{params[:filter] == 'auxiliar_pending' ? 'btn-warning' : 'btn-outline-warning'}" do %>
          Sin revisar (<%= @stats[:pending] %>)
        <% end %>
        <%= link_to taxes_reconciliation_path(@period, filter: "auxiliar_effect"),
              class: "btn btn-sm #{params[:filter] == 'auxiliar_effect' ? 'btn-info' : 'btn-outline-info'}" do %>
          Con ajuste (<%= @stats[:with_effect] %>)
        <% end %>
        <%= link_to taxes_reconciliation_path(@period, filter: "auxiliar_deferred"),
              class: "btn btn-sm #{params[:filter] == 'auxiliar_deferred' ? 'btn-success' : 'btn-outline-success'}" do %>
          Con ID (<%= @stats[:with_deferred] %>)
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# ── Tabla de Auxiliares ─────────────────────────────────────────────── %>
  <% if @items.any? %>
    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" style="font-size:0.82rem">
          <thead class="table-dark">
            <tr>
              <th style="min-width:120px">Código</th>
              <th style="min-width:220px">Nombre</th>
              <th class="text-end" style="min-width:120px">Saldo Contable</th>
              <th class="text-center" style="min-width:100px">Efecto Fiscal</th>
              <th class="text-end" style="min-width:120px">Ajuste Fiscal</th>
              <th class="text-end" style="min-width:120px">Saldo Fiscal</th>
              <th class="text-end" style="min-width:120px">Dif. Temporaria</th>
              <th class="text-end" style="min-width:110px">Imp. Diferido</th>
              <th class="text-center" style="min-width:90px">Clasif. ID</th>
              <th style="width:46px"></th>
            </tr>
          </thead>
          <tbody>
            <% @items.each do |item| %>
              <%
                row_bg = case
                when item.review_status == "pending"
                  ""     # sin color, pendiente
                when item.fiscal_adjustment_cents.to_i != 0
                  "table-warning"   # tiene ajuste
                else
                  "table-success"   # revisado sin ajuste
                end
              %>
              <tr class="<%= row_bg %>">
                <td>
                  <code class="text-primary fw-semibold"><%= item.account_code %></code>
                  <% if item.account_type.present? %>
                    <span class="badge bg-light text-muted border ms-1" style="font-size:0.65rem">
                      <%= item.account_type %>
                    </span>
                  <% end %>
                </td>

                <td>
                  <span class="<%= item.review_status == 'pending' ? 'text-muted' : '' %>">
                    <%= item.account_name %>
                  </span>
                  <% if item.adjustment_comment.present? %>
                    <br>
                    <span class="text-muted" style="font-size:0.73rem">
                      <i class="bi bi-chat-left-text me-1"></i><em><%= item.adjustment_comment.truncate(60) %></em>
                    </span>
                  <% end %>
                </td>

                <td class="text-end fw-semibold"><%= format_cop(item.closing_balance_cents) %></td>

                <td class="text-center"><%= fiscal_effect_badge(item.has_fiscal_effect) %></td>

                <td class="text-end">
                  <% if item.fiscal_adjustment_cents.to_i != 0 %>
                    <span class="fw-bold <%= item.fiscal_adjustment_cents > 0 ? 'text-success' : 'text-danger' %>">
                      <%= format_cop_signed(item.fiscal_adjustment_cents) %>
                    </span>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>

                <td class="text-end">
                  <% if item.fiscal_balance_cents %>
                    <strong><%= format_cop(item.fiscal_balance_cents) %></strong>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>

                <td class="text-end">
                  <% if item.temporary_difference_cents.to_i != 0 %>
                    <span class="fw-bold <%= item.temporary_difference_cents > 0 ? 'text-warning' : 'text-danger' %>">
                      <%= format_cop_signed(item.temporary_difference_cents) %>
                    </span>
                  <% else %>
                    <span class="text-muted">0</span>
                  <% end %>
                </td>

                <td class="text-end">
                  <% if item.deferred_tax_amount_cents.to_i > 0 %>
                    <strong><%= format_cop(item.deferred_tax_amount_cents) %></strong>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>

                <td class="text-center">
                  <% if item.deferred_tax_amount_cents.to_i > 0 %>
                    <%= deferred_tax_badge(item.deferred_tax_classification) %>
                  <% else %>
                    <span class="text-muted small">—</span>
                  <% end %>
                </td>

                <td class="text-center">
                  <% if @period.editable? %>
                    <%= link_to taxes_reconciliation_path(@period, edit_item: item.id,
                                  filter: params[:filter], q: params[:q]),
                          class: "btn btn-sm #{item.review_status == 'pending' ? 'btn-warning' : 'btn-outline-secondary'}",
                          title: item.review_status == "pending" ? "Revisar cuenta" : "Editar conciliación" do %>
                      <i class="bi bi-pencil-square"></i>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>

          <tfoot class="table-dark fw-bold">
            <% all_aux = @period.reconciliation_items.where(account_type: "Auxiliar") %>
            <tr>
              <td colspan="2">
                TOTALES
                <small class="fw-normal text-white-50 ms-2">
                  (<%= @items.count %> de <%= @stats[:auxiliar_total] %> mostrando)
                </small>
              </td>
              <td class="text-end"><%= format_cop(@items.sum(:closing_balance_cents)) %></td>
              <td></td>
              <td class="text-end"><%= format_cop_signed(@items.sum(:fiscal_adjustment_cents)) %></td>
              <td class="text-end"><%= format_cop(@items.where.not(fiscal_balance_cents: nil).sum(:fiscal_balance_cents)) %></td>
              <td class="text-end"><%= format_cop_signed(@items.sum(:temporary_difference_cents)) %></td>
              <td class="text-end"><%= format_cop(@items.sum(:deferred_tax_amount_cents)) %></td>
              <td colspan="2"></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

  <% elsif @stats[:auxiliar_total] == 0 %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <i class="bi bi-file-earmark-spreadsheet fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">Sin cuentas importadas</h5>
        <p class="text-muted small">Carga el balance de comprobación desde Excel. Solo se importarán cuentas de nivel Auxiliar.</p>
      </div>
    </div>
  <% else %>
    <div class="alert alert-info">
      <i class="bi bi-funnel me-2"></i>Sin resultados para el filtro/búsqueda actual.
      <%= link_to "Ver todas las cuentas", taxes_reconciliation_path(@period), class: "alert-link" %>
    </div>
  <% end %>

  <%# ── Modal de conciliación ───────────────────────────────────────────── %>
  <% if @editing_item %>
    <div class="modal fade" id="editItemModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header bg-light">
            <h5 class="modal-title">
              <i class="bi bi-pencil-square me-2 text-primary"></i>
              Conciliar &nbsp;<code class="text-primary"><%= @editing_item.account_code %></code>
            </h5>
            <%= link_to taxes_reconciliation_path(@period, filter: params[:filter], q: params[:q]),
                  class: "btn-close", aria: { label: "Cerrar" } %>
          </div>

          <div class="px-4 pt-3 pb-2 bg-light border-bottom">
            <div class="row g-2 small">
              <div class="col-md-7">
                <span class="text-muted">Nombre:</span>
                <strong> <%= @editing_item.account_name %></strong>
              </div>
              <div class="col-md-5">
                <span class="text-muted">Saldo contable:</span>
                <strong class="text-primary"> <%= format_cop(@editing_item.closing_balance_cents) %></strong>
              </div>
            </div>
          </div>

          <%= form_with url: taxes_reconciliation_item_path(@editing_item),
                method: :patch, html: { "data-turbo" => "false" } do |f| %>
            <div class="modal-body">

              <%# Paso 1 %>
              <p class="fw-semibold mb-2">
                <span class="badge bg-primary rounded-pill me-1">1</span>
                ¿El saldo fiscal de esta cuenta difiere del saldo contable?
              </p>
              <div class="d-flex flex-column gap-2 ps-3 mb-4">
                <div class="form-check">
                  <input class="form-check-input" type="radio"
                         name="reconciliation_item[has_fiscal_effect]"
                         id="effect_no" value="false"
                         <%= @editing_item.has_fiscal_effect == false ? "checked" : "" %>>
                  <label class="form-check-label" for="effect_no">
                    <span class="badge bg-success">No</span>
                    <span class="text-muted ms-1">Saldo contable = Saldo fiscal. No hay diferencia.</span>
                  </label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio"
                         name="reconciliation_item[has_fiscal_effect]"
                         id="effect_yes" value="true"
                         <%= @editing_item.has_fiscal_effect == true ? "checked" : "" %>>
                  <label class="form-check-label" for="effect_yes">
                    <span class="badge bg-warning text-dark">Sí</span>
                    <span class="text-muted ms-1">Existe diferencia contable-fiscal. Registrar ajuste.</span>
                  </label>
                </div>
              </div>

              <%# Razón de exclusión %>
              <div id="exclusion_section" class="<%= @editing_item.has_fiscal_effect == false ? '' : 'd-none' %> mb-4">
                <label class="form-label small text-muted mb-1">
                  Razón de exclusión <span class="fw-normal">(opcional)</span>
                </label>
                <textarea name="reconciliation_item[exclusion_reason]"
                          class="form-control form-control-sm" rows="2"
                          placeholder="Ej: Cuenta de control sin diferencia entre base contable y fiscal."><%= @editing_item.exclusion_reason %></textarea>
              </div>

              <%# Paso 2: Ajuste %>
              <div id="adjustment_section" class="<%= @editing_item.has_fiscal_effect == true ? '' : 'd-none' %>">
                <hr class="my-3">
                <p class="fw-semibold mb-2">
                  <span class="badge bg-primary rounded-pill me-1">2</span>
                  Valor del ajuste fiscal <span class="text-muted fw-normal">(en pesos $)</span>
                </p>
                <div class="input-group mb-1" style="max-width:300px">
                  <span class="input-group-text">$</span>
                  <input type="number" step="1"
                         name="reconciliation_item[fiscal_adjustment_cents]"
                         class="form-control" id="adjustment_input"
                         placeholder="Ej: -3000000"
                         value="<%= @editing_item.fiscal_adjustment_cents.to_i / 100 %>">
                </div>
                <div class="form-text mb-3">
                  <strong>+</strong> el saldo fiscal es mayor &nbsp;|&nbsp;
                  <strong>−</strong> el saldo fiscal es menor<br>
                  <em>Saldo fiscal = Saldo contable + Ajuste</em>
                </div>

                <div class="alert alert-primary py-2 small mb-3" id="fiscal_preview">
                  <i class="bi bi-calculator me-1"></i>
                  Saldo fiscal: <strong id="preview_value">
                    <%= format_cop(@editing_item.fiscal_balance_cents || @editing_item.closing_balance_cents) %>
                  </strong>
                  &nbsp;·&nbsp;
                  Dif. temporaria: <strong id="preview_diff">
                    <%= @editing_item.fiscal_balance_cents ? format_cop_signed(@editing_item.temporary_difference_cents) : "$0" %>
                  </strong>
                </div>

                <p class="fw-semibold mb-2">
                  <span class="badge bg-primary rounded-pill me-1">3</span>
                  Justificación del ajuste <span class="text-danger">*</span>
                  <span class="text-muted fw-normal small">(mínimo 10 caracteres)</span>
                </p>
                <textarea name="reconciliation_item[adjustment_comment]"
                          class="form-control" rows="3" id="adjustment_comment"
                          placeholder="Ej: Multa no deducible Art. 107 E.T. Valor $3.000.000."><%= @editing_item.adjustment_comment %></textarea>
              </div>

              <% if @editing_item.reconciliation_item_changes.any? %>
                <details class="mt-4">
                  <summary class="text-muted small" style="cursor:pointer">
                    <i class="bi bi-clock-history me-1"></i>
                    Historial (<%= @editing_item.reconciliation_item_changes.count %> cambio/s)
                  </summary>
                  <table class="table table-sm table-bordered small mt-2">
                    <thead class="table-light">
                      <tr><th>Campo</th><th>Antes</th><th>Después</th><th>Fecha</th></tr>
                    </thead>
                    <tbody>
                      <% @editing_item.reconciliation_item_changes.order(created_at: :desc).limit(8).each do |ch| %>
                        <tr>
                          <td><code><%= ch.field_name %></code></td>
                          <td class="text-muted"><%= ch.old_value.presence || "—" %></td>
                          <td><%= ch.new_value.presence || "—" %></td>
                          <td class="text-muted"><%= ch.created_at.strftime("%d/%m %H:%M") %></td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </details>
              <% end %>

            </div>

            <div class="modal-footer">
              <%= link_to "Cancelar",
                    taxes_reconciliation_path(@period, filter: params[:filter], q: params[:q]),
                    class: "btn btn-outline-secondary" %>
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i>Guardar conciliación
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        new bootstrap.Modal(document.getElementById('editItemModal')).show();

        document.querySelectorAll('input[name="reconciliation_item[has_fiscal_effect]"]')
          .forEach(function(r) {
            r.addEventListener('change', function() {
              document.getElementById('adjustment_section').classList.toggle('d-none', this.value !== 'true');
              document.getElementById('exclusion_section').classList.toggle('d-none', this.value !== 'false');
            });
          });

        var contableCents = <%= @editing_item.closing_balance_cents.to_i %>;
        var inp = document.getElementById('adjustment_input');
        if (inp) {
          inp.addEventListener('input', function() {
            var adj = parseFloat(this.value) || 0;
            var fp  = (contableCents / 100) + adj;
            var dp  = (contableCents / 100) - fp;
            document.getElementById('preview_value').textContent =
              '$ ' + fp.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
            var de = document.getElementById('preview_diff');
            de.textContent = (dp >= 0 ? '+' : '') +
              '$ ' + dp.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
            de.className = dp !== 0 ? (dp > 0 ? 'fw-bold text-warning' : 'fw-bold text-danger') : '';
          });
        }
      });
    </script>
  <% end %>

</div>
