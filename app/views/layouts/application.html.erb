<!DOCTYPE html>
<html>
  <head>
    <title>Excel a XML</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
      :root {
        --color-primary:    #7c3aed;
        --color-primary-dk: #4a1a7a;
        --color-primary-lt: #ede9fe;
        --color-bg:         #faf5ff;
      }
      body { background-color: var(--color-bg); }

      .navbar { background-color: var(--color-primary-dk) !important; }

      .card-header.bg-primary { background-color: var(--color-primary) !important; }

      .btn-primary {
        background-color: var(--color-primary);
        border-color: var(--color-primary);
      }
      .btn-primary:hover, .btn-primary:focus {
        background-color: var(--color-primary-dk);
        border-color: var(--color-primary-dk);
      }

      .upload-area {
        background-color: var(--color-primary-lt);
        border-color: #c4b5fd !important;
        transition: background 0.2s;
      }
      .upload-area:hover { background-color: #ddd6fe; }

      .text-primary { color: var(--color-primary) !important; }

      .navbar-brand { font-weight: 600; }

      .alert-success { border-left: 4px solid var(--color-primary); }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-dark bg-primary">
      <div class="container">
        <span class="navbar-brand">
          <i class="bi bi-file-earmark-code me-2"></i>Excel → XML
        </span>
      </div>
    </nav>

    <main>
      <%= yield %>
    </main>

    <footer class="text-center text-muted py-4 mt-5 small">
      Excel a XML Converter &copy; <%= Time.now.year %>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
